            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
            width: 100%;
            flex-wrap: nowrap;
        }

        .payment-info-row .payment-info-col {
            width: 100%;
        }

        /* Maksājuma informācija: viena horizontāla rinda (visi rēķinu veidi) */
        .payment-info-row--cols-4 {
            flex-direction: row;
            flex-wrap: nowrap;
            align-items: flex-start;
            justify-content: space-between;
            gap: 10px;
        }

        .payment-info-row--cols-4 .payment-info-col {
            flex: 1 1 0;
            min-width: 0;
            width: auto;
        }

        .payment-info-row--cols-2 {
            flex-direction: row;
            flex-wrap: nowrap;
            align-items: flex-start;
            justify-content: flex-start;
            gap: 28px;
        }

        .payment-info-row--cols-2 .payment-info-col {
            flex: 1 1 0;
            min-width: 0;
            max-width: 50%;
            width: auto;
        }

        .payment-info-col {
            display: flex;
            flex-direction: column;
            gap: 2.28px;
            min-width: 0;
        }

        .payment-legal {
            font-weight: 400;
            font-size: 7px;
            line-height: 9px;
            color: rgba(0, 0, 0, 0.4);
            max-width: 100%;
            margin: 0;
            padding: 0;
        }

        .payment-legal p {
            margin: 0;
            padding: 0;
        }

        .payment-legal p + p {
            margin-top: 2px;
        }

        /* --- Footer (līnija = pilns platums starp 32px / 33px no lapas malas) --- */
        .invoice-footer {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding-top: 16px;
            flex-shrink: 0;
        }

        .invoice-footer-divider {
            width: 100%;
            height: 0.5px;
            background: #CCCCCC;
            border-radius: 3.42073px;
            border: none;
            margin: 0;
            padding: 0;
            flex-shrink: 0;
        }

        .invoice-footer-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 9.44px;
        }

        .invoice-footer-left {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
        }

        .invoice-footer-left img {
            height: 10px;
            width: auto;
            display: block;
            flex-shrink: 0;
        }

        .invoice-footer-right {
            max-width: 310.15px;
            text-align: right;
            min-width: 0;
        }

        .footer-small {
            font-family: 'Inter', sans-serif;
            font-weight: 400;
            font-size: 6px;
            line-height: 7px;
            color: #22201F;
            opacity: 0.3;
        }
    </style>
