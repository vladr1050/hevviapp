            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: flex-start;
            align-self: stretch;
            width: 100%;
            min-height: 47px;
            background: #D7FF01;
            border-radius: 8px;
            padding: 12px 18px 12px 27px;
            gap: 10px;
            box-sizing: border-box;
        }

        .payment-notice-total-banner__left {
            display: flex;
            flex-direction: column;
            gap: 10px;
            align-items: flex-start;
            flex: 1;
            min-width: 0;
        }

        .payment-notice-total-banner__title {
            font-family: 'Instrument Sans', sans-serif;
            font-weight: 600;
            font-size: 10px;
            line-height: 12px;
            letter-spacing: 0.02em;
            text-transform: uppercase;
            color: #000;
            margin: 0;
            padding: 0;
        }

        .payment-notice-total-banner__hint {
            font-family: 'Instrument Sans', sans-serif;
            font-weight: 400;
            font-size: 7px;
            line-height: 9px;
            color: #000;
            margin: 0;
            padding: 0;
            max-width: 100%;
        }

        .payment-notice-total-banner__right {
            display: flex;
            flex-direction: row;
            align-items: baseline;
            justify-content: flex-end;
            gap: 5px;
            flex-shrink: 0;
        }

        .payment-notice-total-banner__amount {
            font-family: 'Instrument Sans', sans-serif;
            font-weight: 600;
            font-size: 18px;
            line-height: 22px;
            color: #000;
            margin: 0;
            padding: 0;
