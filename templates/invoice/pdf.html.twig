<!DOCTYPE html>
<html lang="lv">
<head>
    <meta charset="UTF-8">
    <title>Rēķins {{ invoice_number }}</title>
    <style>
        /* @fontsource/* — пути fonts/* относительно index.html во временной папке (ChromiumInvoicePdfRenderer). */
