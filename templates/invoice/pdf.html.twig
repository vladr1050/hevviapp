        .payment-notice-total-banner__currency {
            font-family: 'Instrument Sans', sans-serif;
            font-weight: 600;
            font-size: 10px;
            line-height: 12px;
            color: #000;
            margin: 0;
            padding: 0;
        }

        /* --- Payment --- */
        .payment-section {
            display: flex;
            flex-direction: column;
            gap: 18px;
            flex-shrink: 0;
        }

        .payment-head {
            display: flex;
            flex-direction: column;
            gap: 9px;
        }

        .payment-title-row {
            display: flex;
            align-items: center;
            gap: 4.56px;
        }

        .payment-content {
            display: flex;
            flex-direction: column;
            gap: 9px;
        }

        /* Вертикальный стек: каждая пара label/value — блок друг под другом */
