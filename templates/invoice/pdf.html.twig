                                <div class="field-label">Saņēmējs:</div>
                                <div class="field-value">{{ seller_name }}</div>
                            </div>
                            <div class="payment-info-col">
                                <div class="field-label">IBAN:</div>
                                <div class="field-value">{{ seller_iban|default('—') }}</div>
                            </div>
