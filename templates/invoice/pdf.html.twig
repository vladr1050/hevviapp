                                    <span class="service-label-line">Kravas piegādes</span>
                                    <span class="service-label-line">maksa (bez PVN)</span>
                                </div>
                                <div class="service-value">{{ amount_freight }}</div>
                            </div>
                            <div class="service-cell">
                                <div class="service-label-lines">
                                    <span class="service-label-line">Hevvi.app komisija</span>
                                    <span class="service-label-line">{{ fee_percent_label }}% (bez PVN)</span>
                                </div>
                                <div class="service-value">{{ amount_commission }}</div>
                            </div>
                            <div class="service-cell">
                                <div class="service-label-lines">
                                    <span class="service-label-line">Starpsumma</span>
                                    <span class="service-label-line">(bez PVN)</span>
                                </div>
