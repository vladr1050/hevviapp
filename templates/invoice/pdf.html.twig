                            </div>
                            <div class="service-cell">
                                <div class="service-label-lines">
                                    <span class="service-label-line">PVN</span>
                                    <span class="service-label-line">{{ vat_percent_label }}%</span>
                                </div>
                                <div class="service-value">{{ amount_vat }}</div>
                            </div>
                            <div class="service-cell service-cell--total">
                                <div class="service-label-lines">
                                    <span class="service-label-line">Kopā apmaksai</span>
                                    <span class="service-label-line">(ar PVN)</span>
                                </div>
                                <div class="service-value service-value--gross">{{ amount_gross }}</div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </section>

            <section class="payment-section">
                <div class="payment-head">
                    <div class="payment-title-row">
                        <span class="icon-bubble icon-bubble--pay" aria-hidden="true"><img src="invoice-assets/fi-157977.svg" alt=""></span>
                        <span class="payment-title-text">Maksājuma informācija</span>
                    </div>
                    <hr class="payment-divider" />
                </div>
                <div class="payment-content">
                    {% if document_type|default('') == 'PAYMENT_NOTICE' %}
                        <div class="payment-info-row payment-info-row--cols-4">
                            <div class="payment-info-col">
                                <div class="field-label">Maksājuma veids:</div>
