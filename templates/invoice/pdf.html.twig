                                <div class="service-line-table__label">Pakalpojums</div>
                                <div class="service-line-table__value service-line-table__value--multiline">Kravas pārvadājumi.{% if vehicle_plate|default('') != '' and vehicle_plate != '—' %}<br>Auto reģ. Nr.: {{ vehicle_plate }}{% endif %}</div>
                            </div>
                            <div class="service-line-table__col">
                                <div class="service-line-table__label">Daudzums</div>
                                <div class="service-line-table__value">1 gab</div>
                            </div>
                            <div class="service-line-table__col">
                                <div class="service-line-table__label">Summa bez PVN</div>
                                <div class="service-line-table__value">{{ amount_freight }}</div>
                            </div>
                            <div class="service-line-table__col">
                                <div class="service-line-table__label">PVN likme</div>
                                <div class="service-line-table__value">{{ vat_percent_label }}%</div>
                            </div>
                            <div class="service-line-table__col">
                                <div class="service-line-table__label">PVN summa</div>
                                <div class="service-line-table__value">{{ amount_vat }}</div>
                            </div>
                            <div class="service-line-table__col service-line-table__col--end">
                                <div class="service-line-table__label">Total {{ invoice_currency }}</div>
                                <div class="service-line-table__value service-line-table__value--strong">{{ amount_gross }}</div>
                            </div>
                        </div>
                    {% else %}
                        <div class="service-header-row">
                            <div class="service-title-row">
                                <span class="icon-bubble icon-bubble--service" aria-hidden="true"><img src="invoice-assets/delivered-1.svg" alt=""></span>
                                <span class="service-title-text">Pakalpojums</span>
                            </div>
                            <div class="service-date">Pakalpojuma sniegšanas datums: {{ service_date }}</div>
                        </div>
                        <hr class="service-divider" />
                        <div class="service-grid">
                            <div class="service-cell">
