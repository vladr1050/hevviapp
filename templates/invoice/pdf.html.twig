            src: url('fonts/instrument-sans-latin-600-normal.woff2') format('woff2');
            unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
        }
        @font-face {
            font-family: 'Instrument Sans';
            font-style: normal;
            font-weight: 700;
            font-display: swap;
            src: url('fonts/instrument-sans-latin-ext-700-normal.woff2') format('woff2');
            unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
        }
        @font-face {
            font-family: 'Instrument Sans';
            font-style: normal;
            font-weight: 700;
            font-display: swap;
            src: url('fonts/instrument-sans-latin-700-normal.woff2') format('woff2');
            unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
        }
        @font-face {
            font-family: 'Inter';
            font-style: normal;
            font-weight: 400;
            font-display: swap;
            src: url('fonts/inter-latin-ext-400-normal.woff2') format('woff2');
            unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
        }
        @font-face {
            font-family: 'Inter';
            font-style: normal;
            font-weight: 400;
            font-display: swap;
            src: url('fonts/inter-latin-400-normal.woff2') format('woff2');
            unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
        }

        @page { size: A4; margin: 0; }
        * { box-sizing: border-box; }
        html, body {
            margin: 0;
            padding: 0;
            font-family: 'Instrument Sans', ui-sans-serif, system-ui, sans-serif;
            font-size: 9px;
            line-height: 1.25;
            color: #000;
            background: #fff;
        }
        /* Figma SVG export 595×842 pt = A4; grid 48 + 240 + 20 + 240, rules x=32 w=530 */
        .page {
            width: 595pt;
            min-height: 842pt;
            padding: 30pt 47pt 38pt 48pt;
            position: relative;
        }
        .hdr-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 11pt;
            width: 500pt;
        }
        .title { font-size: 18px; font-weight: 600; }
        .meta { display: flex; gap: 24px; }
        .meta-block .lbl { color: rgba(0,0,0,0.4); font-size: 7px; }
        .meta-block .val { font-size: 9px; font-weight: 500; margin-top: 2px; }
        .logo-block { text-align: right; max-width: 120pt; }
        .logo-mark {
            height: 16pt;
            width: auto;
            max-width: 113pt;
            display: block;
            margin-left: auto;
        }
        hr.line {
            border: none;
            border-top: 0.5pt solid #CCCCCC;
            width: 100%;
            margin: 8pt 0;
        }
        /* Только линия под шапкой и футером: x=32, w=530 в макете */
        hr.line--bleed530 {
            width: 530pt;
            max-width: none;
            margin-left: -16pt;
            margin-right: 0;
        }
        .two-col { display: flex; gap: 20pt; margin-top: 6px; width: 500pt; }
        .col { width: 240pt; flex: 0 0 240pt; min-width: 0; }
        /* Figma: поставщик/покупатель — только заголовок 9px; Maršruts/Pakalpojums/оплата — зелёный круг + иконка */
        .sec-title { font-weight: 600; font-size: 9px; line-height: 11px; margin-bottom: 6px; }
        .sec-title--plain { display: block; }

        /* --- Шапка + линия 530 + поставщик/покупатель: печатный масштаб, фиксированный A4 --- */
        .invoice-lead {
            font-size: 12px;
            line-height: 1.45;
            padding-top: 12pt;
        }
        .invoice-lead .hdr-row {
            width: 530pt;
            max-width: none;
            margin-left: -16pt;
            margin-bottom: 26pt;
            align-items: flex-start;
        }
        .invoice-lead .title {
            font-size: 28px;
            font-weight: 600;
            line-height: 34px;
            letter-spacing: -0.02em;
        }
        .invoice-lead .meta {
            gap: 36px;
            flex-shrink: 0;
        }
        .invoice-lead .meta-block .lbl {
            font-size: 9px;
            line-height: 11px;
            color: rgba(0, 0, 0, 0.42);
        }
        .invoice-lead .meta-block .val {
            font-size: 12px;
            font-weight: 600;
            line-height: 15px;
            margin-top: 6px;
            color: #111827;
        }
        .invoice-lead .logo-block {
            max-width: 140pt;
            flex-shrink: 0;
        }
        .invoice-lead .logo-mark {
            height: 24pt;
            max-width: 126pt;
        }
        .invoice-lead__divider {
            margin-top: 0;
            margin-bottom: 14pt;
        }
        .invoice-lead .two-col--lead {
            width: 530pt;
            max-width: none;
            margin-left: -16pt;
            margin-top: 28pt;
            gap: 22pt;
            align-items: flex-start;
        }
        .invoice-lead .two-col--lead .col {
            width: 254pt;
            flex: 0 0 254pt;
            min-width: 0;
        }
        .invoice-lead .sec-title--plain {
            font-size: 13px;
            font-weight: 600;
            line-height: 16px;
            margin-bottom: 11px;
        }
        .invoice-lead .col > hr.line {
            margin-top: 0;
            margin-bottom: 11pt;
        }
        .invoice-lead .lbl-sm {
            font-size: 9px;
            line-height: 12px;
            color: rgba(0, 0, 0, 0.45);
        }
        .invoice-lead .val-sm {
            font-size: 12px;
            font-weight: 600;
            line-height: 15px;
            color: #111827;
        }
        .invoice-lead .lbl-sm + .val-sm {
            margin-top: 5px;
        }
        .invoice-lead .pair-row {
            margin-top: 14pt;
        }
        .invoice-lead .addr-block {
            margin-top: 14pt;
        }
        .invoice-lead .addr-block .val-sm {
            line-height: 1.55;
            font-weight: 600;
        }
        .invoice-lead .addr-block .lbl-sm + .val-sm {
            margin-top: 6px;
        }
        .invoice-lead .addr-block .val-sm + .val-sm {
            margin-top: 5px;
        }
        .invoice-lead .addr-block + .pair-row {
            margin-top: 22pt;
        }
        .sec-title--icon {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 4.56pt;
            min-height: 22.8pt;
        }
        .route-wrap .sec-title--icon {
            font-size: 14px;
            font-weight: 600;
            line-height: 17px;
            min-height: 28pt;
            gap: 7pt;
        }
        .sec-icon {
            width: 23.84pt;
            height: 23.84pt;
            min-width: 23.84pt;
            min-height: 23.84pt;
            border-radius: 11.92pt;
            background: #D7FF01;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            box-sizing: border-box;
            padding: 4.77pt;
        }
        .route-wrap .sec-icon {
            width: 28pt;
            height: 28pt;
            min-width: 28pt;
            min-height: 28pt;
            border-radius: 14pt;
            padding: 5.5pt;
        }
        .route-wrap .sec-icon img { width: 15.5pt; height: 15.5pt; }
        .sec-icon img { width: 13.11pt; height: 13.11pt; display: block; object-fit: contain; }
        .sec-icon--service {
            width: 26pt;
            height: 26pt;
            min-width: 26pt;
            min-height: 26pt;
            border-radius: 13pt;
            padding: 0;
        }
        .sec-icon--service img { width: 13pt; height: 13pt; }
        .svc-head .sec-title--icon {
            font-size: 14px;
            font-weight: 600;
            line-height: 17px;
            min-height: 28pt;
            gap: 7pt;
        }
        .sec-icon--pay {
            width: 22.8pt;
            height: 22.8pt;
            min-width: 22.8pt;
            min-height: 22.8pt;
            border-radius: 11.4pt;
            padding: 4.56pt;
        }
        .sec-icon--pay img { width: 9pt; height: 9pt; }
        .lbl-sm { color: rgba(0,0,0,0.4); font-size: 6.8px; }
        .val-sm { font-size: 9px; font-weight: 500; margin-top: 2px; }
        .pair-row { display: flex; gap: 20pt; margin-top: 8px; }
        .pair { flex: 1; min-width: 0; }
        .addr-block { margin-top: 8px; }
        /* Maršruts: сетка 0.95fr / 1.35fr (карта доминирует), gap 32px = PHP ROUTE_GRID_GAP_PX */
        .route-wrap {
            display: grid;
            grid-template-columns: 0.95fr 1.35fr;
            gap: 32px;
            align-items: center;
            width: 530pt;
            max-width: none;
            margin-left: -16pt;
            margin-top: 36px;
        }
        .route-left { min-width: 0; }
        .route-left > hr.line {
            width: 100%;
            margin-top: 0;
            margin-bottom: 14px;
        }
        .route-timeline-wrap {
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            gap: 10pt;
            padding-left: 0;
            margin-top: 4px;
        }
        .timeline-rail-svg {
            width: 5.13184pt;
            height: 76pt;
            flex-shrink: 0;
            display: block;
            object-fit: fill;
        }
        /* Текст справа от рейки — без дублирующей CSS-линии */
        .timeline { position: relative; flex: 1; min-width: 0; }
        .timeline--with-rail { padding-left: 0; }
        .timeline--with-rail::before { display: none; }
        .timeline--with-rail .tl-item::before { display: none; }
        .tl-item { position: relative; margin-bottom: 0; padding-left: 0; }
        .route-timeline-wrap .timeline .tl-item + .tl-item { margin-top: 18px; }
        .route-addr-label {
            font-size: 11px;
            line-height: 13px;
            font-weight: 400;
            color: #9CA3AF;
        }
        .route-addr-value {
            font-size: 17px;
            line-height: 22px;
            font-weight: 600;
            color: #111827;
            margin-top: 6px;
        }
        /* Карта: высота/бордер = PHP MAP_BOX_H_PX / MAP_BORDER_PX */
        .map-box {
            width: 100%;
            height: 280px;
            box-sizing: border-box;
            border: 3px solid #000000;
            border-radius: 18px;
            position: relative;
            background: #e8e8e8;
            overflow: hidden;
        }
        .map-box-inner {
            position: absolute;
            left: 3px;
            top: 3px;
            right: 3px;
            bottom: 3px;
        }
        .map-box-inner .map-tile-img {
            position: absolute;
            display: block;
            margin: 0;
            padding: 0;
            border: 0;
        }
        .map-box-inner img.map-fill {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            display: block;
        }
        .map-route-svg {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
            overflow: visible;
        }
        /* Pins: макет 12 + 2.85 pt (Pickup — белый, Delivery — #DEDEDE). */
        .map-pin {
            position: absolute;
            width: 13pt;
            height: 13pt;
            box-sizing: content-box;
            border: 2.5px solid #000000;
            border-radius: 50%;
            transform: translate(-50%, -50%);
            z-index: 2;
            box-shadow: 0 2pt 2pt rgba(0, 0, 0, 0.2);
            pointer-events: none;
        }
        .map-pin-pickup { background: #ffffff; }
        .map-pin-drop { background: #DEDEDE; }
        .svc-head {
            display: grid;
            grid-template-columns: 1fr auto;
            align-items: baseline;
            column-gap: 28px;
            margin-top: 32px;
            width: 530pt;
            max-width: none;
            margin-left: -16pt;
        }
        .svc-head .sec-title--icon { min-width: 0; }
        .svc-date {
            text-align: right;
            font-weight: 700;
            font-size: 12px;
            line-height: 17px;
            color: #111827;
            white-space: nowrap;
        }
        hr.line.svc-block-hr {
            margin-top: 14px;
            margin-bottom: 14px;
        }
        .price-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 20px;
            margin-top: 0;
            width: 530pt;
            max-width: none;
            margin-left: -16pt;
        }
        .price-cell { min-width: 0; }
        .price-lbl {
            font-size: 12px;
            line-height: 15px;
            font-weight: 400;
            color: #9CA3AF;
            white-space: normal;
        }
        .price-val {
            font-size: 17px;
            line-height: 22px;
            font-weight: 600;
            color: #111827;
            margin-top: 8px;
            white-space: nowrap;
        }
        .price-cell.total .price-lbl {
            color: #6B7280;
            font-weight: 500;
        }
        .price-cell.total .price-val {
            font-weight: 800;
            font-size: 18px;
            line-height: 23px;
            color: #000000;
        }
        .pay-section { width: 500pt; margin-top: 14px; }
        .pay-grid { display: flex; gap: 48px; margin-top: 8px; }
        .legal-note { color: rgba(0,0,0,0.4); font-size: 7px; max-width: 220px; margin-top: 10px; line-height: 1.35; }
        .footer {
            position: absolute;
            left: -16pt;
            width: 530pt;
            bottom: 28pt;
            padding-top: 6pt;
            border-top: 0.5pt solid #CCCCCC;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
            font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
            font-size: 6px;
            line-height: 7px;
            font-weight: 400;
            color: rgba(34, 32, 31, 0.3);
        }
        .footer .right { text-align: right; max-width: 58%; }
        .footer-left {
            display: flex;
            flex-direction: row;
            align-items: center;
            flex-wrap: wrap;
            gap: 0 3pt;
            max-width: 48%;
        }
        .footer-mark { height: 12pt; width: auto; display: block; flex-shrink: 0; }
    </style>
</head>
<body>
<div class="page">
    <div class="invoice-lead">
    <div class="hdr-row">
        <div class="title">Rēķins</div>
        <div class="meta">
            <div class="meta-block">
                <div class="lbl">Rēķina Nr / Pasūtījuma Nr</div>
                <div class="val">{{ invoice_number }}</div>
            </div>
            <div class="meta-block">
                <div class="lbl">Rēķina datums:</div>
                <div class="val">{{ issue_date }}</div>
            </div>
        </div>
        <div class="logo-block">
            <img src="invoice-assets/group-1122.svg" class="logo-mark" alt="hevvi">
        </div>
    </div>
    <hr class="line line--bleed530 invoice-lead__divider">

    <div class="two-col two-col--lead">
        <div class="col">
            <div class="sec-title sec-title--plain">Pakalpojuma sniedzējs</div>
            <hr class="line">
            <div class="lbl-sm">Pārdevējs (Pakalpojuma sniedzējs):</div>
            <div class="val-sm">{{ seller_name }}</div>
            <div class="pair-row">
                <div class="pair">
                    <div class="lbl-sm">Reģ. Nr.</div>
                    <div class="val-sm">{{ seller_reg }}</div>
                </div>
                <div class="pair">
                    <div class="lbl-sm">PVN reģ. Nr.</div>
                    <div class="val-sm">{{ seller_vat }}</div>
                </div>
            </div>
            <div class="addr-block">
                <div class="lbl-sm">Juridiskā adrese:</div>
                <div class="val-sm">{{ seller_line1 }}</div>
                {% if seller_line2 %}<div class="val-sm">{{ seller_line2 }}</div>{% endif %}
            </div>
            <div class="pair-row">
                <div class="pair">
                    <div class="lbl-sm">E-pasts:</div>
                    <div class="val-sm">{{ seller_email }}</div>
                </div>
                <div class="pair">
                    <div class="lbl-sm">Tālrunis:</div>
                    <div class="val-sm">{{ seller_phone }}</div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="sec-title sec-title--plain">Pakalpojumu saņēmējs</div>
            <hr class="line">
            <div class="lbl-sm">Pircējs (Klients):</div>
            <div class="val-sm">{{ buyer_company }}</div>
            <div class="pair-row">
                <div class="pair">
                    <div class="lbl-sm">Reģ. Nr.</div>
                    <div class="val-sm">{{ buyer_reg }}</div>
                </div>
                <div class="pair">
                    <div class="lbl-sm">PVN reģ. Nr.</div>
                    <div class="val-sm">{{ buyer_vat }}</div>
                </div>
            </div>
            <div class="addr-block">
                <div class="lbl-sm">Adrese:</div>
                {% for line in buyer_address_lines %}
                    <div class="val-sm">{{ line }}</div>
                {% endfor %}
            </div>
        </div>
    </div>
    </div>

    <div class="route-wrap">
        <div class="route-left">
            <div class="sec-title sec-title--icon">
                <span class="sec-icon" aria-hidden="true"><img src="invoice-assets/fi-446075.svg" alt=""></span>
                <span>Maršruts</span>
            </div>
            <hr class="line">
            <div class="route-timeline-wrap">
                <img src="invoice-assets/group-1059.svg" class="timeline-rail-svg" alt="">
                <div class="timeline timeline--with-rail">
                    <div class="tl-item">
                        <div class="route-addr-label">Pickup</div>
                        <div class="route-addr-value">{{ pickup }}</div>
                    </div>
                    <div class="tl-item">
                        <div class="route-addr-label">Delivery</div>
                        <div class="route-addr-value">{{ delivery }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="map-box">
            <div class="map-box-inner">
                {% if map_show_pins and map_inner_w and map_inner_h and map_img_w %}
                    <img class="map-tile-img" src="{{ map_data_uri|raw }}" alt=""
                         style="left: {{ map_img_left }}px; top: {{ map_img_top }}px; width: {{ map_img_w }}px; height: {{ map_img_h }}px;">
                {% else %}
                    <img class="map-fill" src="{{ map_data_uri|raw }}" alt="">
                {% endif %}
                {% if map_show_pins and map_inner_w and map_inner_h %}
                    <svg class="map-route-svg" viewBox="0 0 {{ map_inner_w }} {{ map_inner_h }}" preserveAspectRatio="none" aria-hidden="true">
                        <line x1="{{ map_pickup_left }}" y1="{{ map_pickup_top }}" x2="{{ map_drop_left }}" y2="{{ map_drop_top }}"
                              stroke="#000000" stroke-width="4" stroke-linecap="round"/>
                    </svg>
                    <span class="map-pin map-pin-pickup" style="left: {{ map_pickup_left }}px; top: {{ map_pickup_top }}px;"></span>
                    <span class="map-pin map-pin-drop" style="left: {{ map_drop_left }}px; top: {{ map_drop_top }}px;"></span>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="svc-head">
        <div class="sec-title sec-title--icon" style="margin-top:0">
            <span class="sec-icon sec-icon--service" aria-hidden="true"><img src="invoice-assets/delivered-1.svg" alt=""></span>
            <span>Pakalpojums</span>
        </div>
        <div class="svc-date">Pakalpojuma sniegšanas datums: {{ service_date }}</div>
    </div>
    <hr class="line line--bleed530 svc-block-hr">

    <div class="price-grid">
        <div class="price-cell">
            <div class="price-lbl">Kravas piegādes maksa</div>
            <div class="price-val">{{ amount_freight }}</div>
        </div>
        <div class="price-cell">
            <div class="price-lbl">{{ commission_label }}</div>
            <div class="price-val">{{ amount_commission }}</div>
        </div>
        <div class="price-cell">
            <div class="price-lbl">Starpsumma (bez PVN)</div>
            <div class="price-val">{{ amount_subtotal }}</div>
        </div>
        <div class="price-cell">
            <div class="price-lbl">{{ vat_label }}</div>
            <div class="price-val">{{ amount_vat }}</div>
        </div>
        <div class="price-cell total">
            <div class="price-lbl">KOPĀ APMAKSAI (ar PVN)</div>
            <div class="price-val">{{ amount_gross }}</div>
        </div>
    </div>

    <div class="pay-section">
        <div class="sec-title sec-title--icon">
            <span class="sec-icon sec-icon--pay" aria-hidden="true"><img src="invoice-assets/fi-157977.svg" alt=""></span>
            <span>Maksājuma informācija</span>
        </div>
        <hr class="line">
        <div class="pay-grid">
            <div>
                <div class="lbl-sm">Maksājuma veids</div>
                <div class="val-sm">Bankas pārskaitījums</div>
            </div>
            <div>
                <div class="lbl-sm">Apmaksas termiņš</div>
                <div class="val-sm">{{ due_date }}</div>
            </div>
        </div>
        <div class="legal-note">
            Rēķins sagatavots elektroniski un ir derīgs bez paraksta. PVN piemērots saskaņā ar Pievienotās vērtības nodokļa likumu.
        </div>
    </div>

    <div class="footer">
        <div class="footer-left">
            <img src="invoice-assets/group-1123.svg" class="footer-mark" alt="" aria-hidden="true">
            <span>— Pakalpojums sniegts caur Hevvi digitālo platformu</span>
        </div>
        <div class="right">Hevvi App nodrošina digitālu platformu transporta pakalpojumu organizēšanai. Komisijas maksa tiek ieturēta par platformas izmantošanu un administrēšanu.</div>
    </div>
</div>
</body>
</html>
