        .service-line-table--7 {
            gap: 2px;
        }

        .service-line-table--7 .service-line-table__col {
            flex: 1 1 0;
        }

        .service-line-table--7 .service-line-table__col--partner {
            flex: 1.05 1 0;
            min-width: 40px;
        }

        .service-line-table--7 .service-line-table__col--pakalpojums {
            flex: 1.12 1 0;
            min-width: 44px;
        }

        .service-line-table--7 .service-line-table__value--multiline {
            white-space: normal;
            font-size: 7px;
            line-height: 9px;
        }

        .service-line-table--7 .service-line-table__label {
            font-size: 6.2px;
            line-height: 7.5px;
        }

        .service-line-table--7 .service-line-table__value {
            font-size: 7.5px;
            line-height: 9px;
        }

