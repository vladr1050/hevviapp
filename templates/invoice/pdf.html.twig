        @page { size: A4; margin: 0; }
        * { box-sizing: border-box; }
        /* Page shell: A4 in mm. (595×842px is only ~157×223mm at CSS 96dpi — not full A4.) */
        html, body {
            margin: 0;
            padding: 0;
            width: 210mm;
            height: 297mm;
            background: #fff;
            color: #000;
        }

        .page {
            position: relative;
            width: 210mm;
            height: 297mm;
            background: #fff;
            overflow: hidden;
            box-sizing: border-box;
            font-family: 'Instrument Sans', sans-serif;
        }

        /* Вертикальные поля страницы; горизонталь задаётся padding у header/body/footer. */
        .page-box {
            position: absolute;
            left: 0;
            top: 8.73mm;
            right: 0;
            bottom: 8.73mm;
            width: auto;
            height: auto;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
        }

        .header-region {
            flex: 0 0 auto;
            padding-left: 32px;
            padding-right: 33px;
            box-sizing: border-box;
        }

        .header-region .page-rail-530 {
            zoom: 1.12;
        }

        .body-region {
            flex: 1 1 0;
            min-height: 0;
            margin-top: 57px;
            display: flex;
            flex-direction: column;
            align-items: stretch;
            width: 100%;
            padding-left: 48px;
            padding-right: 47px;
            box-sizing: border-box;
        }

        .footer-region {
            flex: 0 0 auto;
            margin-top: auto;
            padding-left: 32px;
            padding-right: 33px;
            box-sizing: border-box;
        }

        .footer-region .page-rail-530 {
            zoom: 1.12;
        }

        /* Rail шире эталонной колонки 500px после zoom */
        .page-rail-530 {
            width: 100%;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            box-sizing: border-box;
        }

        /* --- Header --- */
        .invoice-header {
            display: flex;
            flex-direction: column;
            gap: 10px;
            flex-shrink: 0;
        }

        .invoice-header-row {
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
        }

        .invoice-header-left {
            display: flex;
            flex-direction: row;
            align-items: flex-start;
            flex: 1 1 auto;
            width: auto;
            max-width: none;
            box-sizing: border-box;
            gap: 18px;
            min-width: 0;
        }

        .invoice-title {
            font-weight: 600;
            font-size: 18.2439px;
            line-height: 22px;
            color: #000;
            margin: 0;
            padding: 0;
            flex-shrink: 0;
        }

        .invoice-meta {
            display: flex;
            flex-wrap: nowrap;
            gap: 28px;
            min-width: 0;
            flex: 1 1 auto;
            flex-shrink: 0;
            align-items: flex-start;
        }

        .invoice-meta-block {
            display: flex;
            flex-direction: column;
            gap: 0;
            flex: 0 0 auto;
            min-width: max-content;
        }

        .invoice-meta-label {
            font-weight: 400;
            font-size: 7px;
            line-height: 9px;
            color: rgba(0, 0, 0, 0.4);
            margin: 0;
            padding: 0;
        }

        .invoice-meta-value {
            font-weight: 500;
            font-size: 9px;
            line-height: 11px;
            color: #000;
            margin: 0;
            margin-top: 2px;
            padding: 0;
            white-space: nowrap;
            word-wrap: normal;
            overflow-wrap: normal;
        }

        .invoice-brand {
            display: flex;
            align-items: flex-start;
            justify-content: flex-end;
            gap: 10px;
            flex-shrink: 0;
        }

        .invoice-brand img {
            display: block;
            width: 112.32px;
            height: 15.97px;
            object-fit: contain;
            object-position: right center;
        }

        .invoice-header-divider {
            width: 100%;
            height: 0.5px;
            background: #CCCCCC;
            border-radius: 3.42073px;
            border: none;
            margin: 0;
            padding: 0;
        }

        /* --- Main: ширина между полями body (48px / 47px от края страницы) --- */
        .invoice-main {
            width: 100%;
            max-width: 100%;
            display: flex;
            flex-direction: column;
            gap: 46px;
            flex-shrink: 0;
            zoom: 1.22;
        }

        /* --- Party --- */
        .party-section {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
            column-gap: 20px;
            width: 100%;
            flex-shrink: 0;
        }

        /* Pārvadātāja rēķins: trīs partneru kartītes (Figma) */
        .party-section.party-section--triple {
            grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr);
            column-gap: 16px;
            align-items: stretch;
            justify-content: space-between;
        }

        .party-card {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 9px;
            width: 100%;
            min-width: 0;
            box-sizing: border-box;
            min-height: 100%;
        }

        .party-section--triple .party-card {
            align-self: stretch;
        }

        .party-card__footer {
            margin-top: auto;
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 6px;
            padding-top: 8px;
        }

        .party-card__footer-row {
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: baseline;
            gap: 6px;
            width: 100%;
            font-size: 7px;
            line-height: 9px;
        }

        .party-card__footer-label {
            font-weight: 400;
            color: rgba(0, 0, 0, 0.4);
            flex-shrink: 0;
        }

        .party-card__footer-value {
            font-weight: 600;
            color: #000;
            text-align: right;
            min-width: 0;
        }

        .party-card__footer-kopa {
            font-weight: 600;
            font-size: 9px;
            line-height: 11px;
            color: #000;
            margin-top: 2px;
        }

        .party-card__header {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 8px;
            width: 100%;
            min-width: 0;
        }

        .party-card__head-text {
            display: flex;
            flex-direction: column;
            gap: 2px;
            min-width: 0;
            flex: 1 1 auto;
        }

        .party-card__title {
            font-weight: 600;
            font-size: 9px;
            line-height: 11px;
            color: #000;
            margin: 0;
            padding: 0;
        }

        .party-card__subtitle {
            font-weight: 400;
            font-size: 7px;
            line-height: 9px;
            color: rgba(0, 0, 0, 0.4);
            margin: 0;
            padding: 0;
        }

        .party-card__divider {
            width: 100%;
            height: 0.5px;
            background: #CCCCCC;
            border: none;
            margin: 0;
            padding: 0;
        }

        .party-card__fields {
            display: flex;
            flex-direction: column;
            gap: 9px;
            width: 100%;
        }

        .party-card .field-label {
            color: #CCCCCC;
        }

        .party-card .field-value {
            font-weight: 600;
        }

        .party-card .icon-bubble--service img.party-card__bubble-partner {
            width: 11.28px;
            height: 11.28px;
            display: block;
            object-fit: contain;
        }

        .party-column {
            display: flex;
            flex-direction: column;
            gap: 9px;
            min-width: 0;
        }

        .party-title {
            font-weight: 600;
            font-size: 9px;
            line-height: 11px;
            color: #000;
            margin: 0;
            padding: 0;
        }

        .party-divider {
            height: 0.47px;
            background: #CCCCCC;
            border-radius: 3.42073px;
            border: none;
            margin: 0;
            padding: 0;
            width: 100%;
        }

        .party-content {
            display: flex;
            flex-direction: column;
            gap: 11.33px;
        }

        .field-stack {
            display: flex;
            flex-direction: column;
            gap: 2.28px;
        }

        .field-row {
            display: flex;
            gap: 25.09px;
        }

        .field-row .field-stack {
            flex: 1;
            min-width: 0;
        }

        .field-label {
            font-weight: 400;
            font-size: 7px;
            line-height: 9px;
            color: rgba(0, 0, 0, 0.4);
            margin: 0;
            padding: 0;
        }

        .field-value {
            font-weight: 500;
            font-size: 9px;
            line-height: 11px;
            color: #000;
            margin: 0;
            padding: 0;
            word-wrap: break-word;
        }

        /* --- Route + service --- */
        .route-service-section {
            display: flex;
            flex-direction: column;
            gap: 46px;
            flex-shrink: 0;
        }

        .route-map-row {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
            column-gap: 20px;
            align-items: start;
            width: 100%;
        }

        .route-column {
            display: flex;
            flex-direction: column;
            gap: 10px;
            min-width: 0;
        }

        .route-title-row {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .icon-bubble {
            width: 23.84px;
            height: 23.84px;
            border-radius: 50%;
            background: #D7FF01;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            padding: 4.77px;
            box-sizing: border-box;
        }

        .icon-bubble img {
            width: 13.11px;
            height: 13.11px;
            display: block;
            object-fit: contain;
        }

        .icon-bubble--service {
            width: 22.56px;
            height: 22.56px;
            padding: 0;
        }

        .icon-bubble--service img {
            width: 11.28px;
            height: 11.28px;
        }

        .icon-bubble--pay {
            width: 22.8px;
            height: 22.8px;
            padding: 4.56px;
        }

        .icon-bubble--pay img {
            width: 9px;
            height: 9px;
        }

        .route-title-text,
        .service-title-text,
        .payment-title-text {
            font-weight: 600;
            font-size: 9px;
            line-height: 11px;
            color: #000;
        }

        .route-divider,
        .service-divider,
        .payment-divider {
            height: 0.5px;
            background: #CCCCCC;
            border: none;
            margin: 0;
            padding: 0;
            width: 100%;
        }

        .route-stops-layout {
            display: grid;
            grid-template-columns: 19px 1fr;
            column-gap: 9.12px;
            align-items: stretch;
        }

        .route-marker-column {
            position: relative;
            width: 19px;
            min-height: 56px;
        }

        .route-marker-column::before {
            content: '';
            position: absolute;
            left: 8.5px;
            top: 9.12px;
            bottom: 9.12px;
            width: 1.14px;
            background: #000;
            border-radius: 3.42073px;
        }

        .route-marker-top,
        .route-marker-bottom {
            width: 9.12px;
            height: 9.12px;
            border: 1.14024px solid #000;
            border-radius: 50%;
            background: #fff;
            position: absolute;
            left: 4px;
            box-sizing: border-box;
        }

        .route-marker-top { top: 0; }
        .route-marker-bottom { bottom: 0; }

        .route-text-side {
            display: flex;
            flex-direction: column;
            gap: 0;
            min-width: 0;
        }

        .route-text {
            display: flex;
            flex-direction: column;
            gap: 2.28px;
        }

        .route-small-label {
            font-weight: 400;
            font-size: 6.84145px;
            line-height: 8px;
            color: rgba(0, 0, 0, 0.4);
            margin: 0;
            padding: 0;
        }

        .route-value {
            font-weight: 500;
            font-size: 9.12193px;
            line-height: 11px;
            color: #000;
            margin: 0;
            padding: 0;
            word-wrap: break-word;
        }

        .route-inner-divider {
            margin: 8px 0 8px 28.506px;
            height: 0.5px;
            background: #CCCCCC;
            border: none;
            padding: 0;
        }

        .map-column {
            width: 100%;
            max-width: 240px;
        }

        .map-preview {
            width: 100%;
            max-width: 240px;
            height: 118px;
            border-radius: 7.98169px;
            overflow: hidden;
            display: block;
            position: relative;
            background: #e8e8e8;
        }

        .map-box-inner {
            position: absolute;
            left: 0;
            top: 0;
            right: 0;
            bottom: 0;
        }

        .map-box-inner .map-tile-img {
            position: absolute;
            display: block;
            margin: 0;
            padding: 0;
            border: 0;
        }

        .map-tile-strip {
            position: absolute;
            display: flex;
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        .map-tile-strip--row {
            flex-direction: row;
        }

        .map-tile-strip--col {
            flex-direction: column;
        }

        .map-tile-strip .map-tile-part {
            display: block;
            margin: 0;
            padding: 0;
            border: 0;
            object-fit: fill;
            flex: 1 1 50%;
        }

        .map-box-inner img.map-fill {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            display: block;
        }

        .map-pin-img {
            position: absolute;
            z-index: 2;
            pointer-events: none;
            display: block;
            width: 16px;
            height: 18px;
            object-fit: contain;
            object-position: center center;
            transform: translate(-50%, -50%);
        }

        /* --- Service --- */
        .service-block {
            display: flex;
            flex-direction: column;
            gap: 9px;
            width: 100%;
            padding-left: 10px;
            padding-right: 10px;
        }

        .service-header-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }

        .service-title-row {
            display: flex;
            align-items: center;
            gap: 4.56px;
            min-width: 0;
        }

        .service-date {
            font-weight: 600;
            font-size: 9px;
            line-height: 11px;
            color: #000;
            text-align: right;
            flex-shrink: 0;
            max-width: 55%;
        }

        .service-header-row--carrier-dates {
            align-items: flex-start;
        }

        .service-date-stack {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 3px;
            flex-shrink: 0;
            max-width: 52%;
            text-align: right;
        }

        .service-date-stack .service-date-line {
            font-weight: 600;
            font-size: 8px;
            line-height: 10px;
            color: #000;
        }

        /* Content-width columns; gaps = equal free space (Figma primary axis “Auto” / space-between). */
        .service-grid {
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: flex-end;
            align-content: flex-end;
            width: 100%;
            box-sizing: border-box;
            gap: 0;
        }

        .service-grid--delivered-split {
            justify-content: flex-start;
            gap: 32px;
            flex-wrap: nowrap;
        }

        .service-cell {
            flex: 0 0 auto;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            gap: 6px;
            align-items: flex-start;
            min-width: 0;
        }

        .service-cell--total {
            align-items: flex-end;
            text-align: right;
        }

        .service-cell--total .service-label-lines {
            align-items: flex-end;
        }

        .service-cell--total .service-label-line {
            text-align: right;
        }

        .service-label-lines {
            display: flex;
            flex-direction: column;
            gap: 2.28px;
            min-width: 0;
        }

        .service-label-line {
            font-weight: 400;
            font-size: 6.84145px;
            line-height: 8px;
            color: rgba(0, 0, 0, 0.4);
            margin: 0;
            padding: 0;
        }

        .service-value {
            font-weight: 500;
            font-size: 9.12193px;
            line-height: 11px;
            color: #000;
            margin: 0;
            padding: 0;
            white-space: nowrap;
        }

        .service-value--gross {
            font-weight: 600;
        }

        /* CUSTOMER_INVOICE (pēc piegādes): viena horizontāla rinda — 6 kolonnas (Figma) */
        .service-line-table {
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: flex-end;
            align-self: stretch;
            width: 100%;
            gap: 4px;
            box-sizing: border-box;
        }

        .service-line-table__col {
            flex: 1 1 0;
            min-width: 0;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            gap: 6px;
            align-items: flex-start;
        }

        .service-line-table__col--service {
            flex: 1.25 1 58px;
            min-width: 58px;
        }

        .service-line-table__col--service .service-line-table__value {
            white-space: normal;
            font-size: 8px;
            line-height: 10px;
        }

        .service-line-table__col--end {
            align-items: flex-end;
            text-align: right;
        }

        .service-line-table__col--end .service-line-table__label,
        .service-line-table__col--end .service-line-table__value {
            text-align: right;
            align-self: flex-end;
        }

        .service-line-table__label {
            font-weight: 400;
            font-size: 6.84145px;
            line-height: 8px;
            color: rgba(0, 0, 0, 0.4);
            margin: 0;
            padding: 0;
        }

        .service-line-table__value {
            font-weight: 500;
            font-size: 9.12193px;
            line-height: 11px;
            color: #000;
            margin: 0;
            padding: 0;
            white-space: nowrap;
        }

        .service-line-table__value--strong {
            font-weight: 600;
        }

