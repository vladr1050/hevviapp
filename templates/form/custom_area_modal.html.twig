{#
/**
 * Custom Area Modal Template
 *
 * Модальное окно для создания/редактирования кастомных гео-зон.
 * Используется в GeoAreaSelectionType для рисования полигонов на карте.
 */
#}

<div class="modal fade"
     id="customAreaModal"
     data-controller="custom-area-modal"
     data-custom-area-modal-target="modal"
     data-custom-area-modal-default-lat-value="{{ map_config.default_latitude }}"
     data-custom-area-modal-default-lng-value="{{ map_config.default_longitude }}"
     data-custom-area-modal-default-zoom-value="{{ map_config.default_zoom }}"
     data-custom-area-modal-translation-name-required-value="{{ 'custom_area.message.name_required'|trans({}, 'AppBundle') }}"
     data-custom-area-modal-translation-geometry-required-value="{{ 'custom_area.message.geometry_required'|trans({}, 'AppBundle') }}"
     data-custom-area-modal-translation-jquery-error-value="{{ 'custom_area.message.jquery_not_loaded'|trans({}, 'AppBundle') }}"
     data-custom-area-modal-translation-draw-error-value="{{ 'custom_area.message.draw_library_not_loaded'|trans({}, 'AppBundle') }}"
     data-custom-area-modal-translation-invalid-geometry-value="{{ 'custom_area.message.invalid_geometry'|trans({}, 'AppBundle') }}"
     data-custom-area-modal-translation-load-error-value="{{ 'custom_area.message.geometry_load_error'|trans({}, 'AppBundle') }}"
     data-custom-area-modal-translation-hexagon-selected-label-value="{{ 'geo_area_selection.hexagon.selected_label'|trans({}, 'AppBundle') }}"
     data-custom-area-modal-translation-hexagon-clear-button-value="{{ 'geo_area_selection.hexagon.clear_button'|trans({}, 'AppBundle') }}"
     data-custom-area-modal-translation-hexagon-click-hint-value="{{ 'geo_area_selection.hexagon.click_hint'|trans({}, 'AppBundle') }}"
     tabindex="-1"
     aria-labelledby="customAreaModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg" style="width: 90%; max-width: 1200px;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="customAreaModalLabel">
                    <i class="fas fa-draw-polygon"></i>
                    {{ 'custom_area.modal.title'|trans({}, 'AppBundle') }}
                </h5>
                <button type="button"
                        class="close"
                        data-dismiss="modal"
                        aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>

            <div class="modal-body">
                <div class="row">
                    {# Сообщение об ошибке #}
                    <div class="col-md-12">
                        <div class="alert alert-danger d-none"
                             data-custom-area-modal-target="errorMessage"
                             role="alert">
                        </div>
                    </div>
                    <div class="col-md-4">
                        {# Поле для названия #}
                        <div class="form-group">
                            <label for="customAreaName" class="form-label">
                                {{ 'custom_area.label.name'|trans({}, 'AppBundle') }}
                            </label>
                            <input type="text"
                                   class="form-control"
                                   id="customAreaName"
                                   data-custom-area-modal-target="nameInput"
                                   placeholder="{{ 'custom_area.placeholder.name'|trans({}, 'AppBundle') }}">
                            <small class="form-text text-muted">
                                {{ 'custom_area.help.name'|trans({}, 'AppBundle') }}
                            </small>
                        </div>

                        {# Статистика выбранных гексагонов #}
                        <div class="alert alert-success" 
                             data-custom-area-modal-target="hexagonStats" 
                             style="display: none;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    <strong><i class="fas fa-check-circle"></i> <span data-custom-area-modal-target="selectedLabel">{{ 'geo_area_selection.hexagon.selected_label'|trans({}, 'AppBundle') }}</span>:</strong>
                                    <span data-custom-area-modal-target="hexagonCount" class="badge bg-primary fs-6">0</span>
                                </div>
                                <button type="button" 
                                        class="btn btn-sm btn-outline-danger"
                                        data-action="custom-area-modal#clearSelectedHexagons"
                                        data-custom-area-modal-target="clearHexagonsButton">
                                    <i class="fas fa-trash"></i> {{ 'geo_area_selection.hexagon.clear_button'|trans({}, 'AppBundle') }}
                                </button>
                            </div>
                            <small class="text-muted d-block">
                                <i class="fas fa-mouse-pointer"></i> 
                                {{ 'geo_area_selection.hexagon.click_hint'|trans({}, 'AppBundle') }}
                            </small>
                        </div>

                        {# Инструкция по использованию #}
                        <div class="alert alert-info" role="alert">
                            <strong>{{ 'custom_area.instruction.title'|trans({}, 'AppBundle') }}</strong>
                            <ul class="mb-0 mt-2 small">
                                <li>{{ 'custom_area.instruction.step1'|trans({}, 'AppBundle') }}</li>
                                <li>{{ 'custom_area.instruction.step2'|trans({}, 'AppBundle') }}</li>
                                <li>{{ 'geo_area_selection.hexagon.instruction_or'|trans({}, 'AppBundle') }}</li>
                                <li>{{ 'custom_area.instruction.step3'|trans({}, 'AppBundle') }}</li>
                                <li>{{ 'custom_area.instruction.step4'|trans({}, 'AppBundle') }}</li>
                            </ul>
                            <hr class="my-2">
                            <small class="text-muted">
                                <i class="fas fa-lightbulb"></i>
                                <strong>{{ 'geo_area_selection.hexagon.instruction_edit_title'|trans({}, 'AppBundle') }}:</strong> {{ 'geo_area_selection.hexagon.instruction_edit'|trans({}, 'AppBundle') }}
                            </small>
                        </div>
                    </div>

                    <div class="col-md-8">
                        {# Панель управления гексагональной сеткой #}
                        <div class="form-group hexagon-controls mb-3 p-2 border rounded bg-light" style="padding: 15px;">
                            <div class="row align-items-center">
                                <div class="col-md-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               id="modalHexagonGridToggle"
                                               data-custom-area-modal-target="hexagonToggle">
                                        <label class="form-check-label" for="modalHexagonGridToggle">
                                            <i class="fas fa-th"></i>
                                            {{ 'geo_area_selection.hexagon.toggle_grid'|trans({}, 'AppBundle') }}
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-8" data-custom-area-modal-target="hexagonResolutionWrapper" style="display: none;">
                                    <label class="form-label mb-1 small">
                                        {{ 'geo_area_selection.hexagon.resolution'|trans({}, 'AppBundle') }}:
                                        <strong data-custom-area-modal-target="resolutionLabel">6</strong>
                                        <small class="text-muted" data-custom-area-modal-target="resolutionInfo">(~36.13 км²)</small>
                                    </label>
                                    <input type="range"
                                           class="form-range"
                                           min="5"
                                           max="6"
                                           value="6"
                                           step="1"
                                           data-custom-area-modal-target="hexagonResolution"
                                           data-action="custom-area-modal#onHexagonResolutionChange">
                                    <div class="d-flex justify-content-between">
                                        <small class="text-muted">5 (252 км²)</small>
                                        <small class="text-muted">6 (36 км²)</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Карта для рисования #}
                        <div class="mb-3">
                            <label class="form-label">
                                {{ 'custom_area.label.draw_area'|trans({}, 'AppBundle') }}
                            </label>
                            <div class="map-container border rounded"
                                 data-custom-area-modal-target="map"
                                 style="height: 500px; width: 100%;"></div>
                            <small class="form-text text-muted mt-2 d-block">
                                <i class="fas fa-info-circle"></i>
                                {{ 'custom_area.help.draw_area'|trans({}, 'AppBundle') }}
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-custom-area-modal-target="cancelButton"
                        data-action="custom-area-modal#cancel">
                    <i class="fas fa-times"></i>
                    {{ 'custom_area.button.cancel'|trans({}, 'AppBundle') }}
                </button>
                <button type="button"
                        class="btn btn-primary"
                        data-custom-area-modal-target="saveButton"
                        data-action="custom-area-modal#save">
                    <i class="fas fa-check"></i>
                    {{ 'custom_area.button.save'|trans({}, 'AppBundle') }}
                </button>
            </div>
        </div>
    </div>
</div>
