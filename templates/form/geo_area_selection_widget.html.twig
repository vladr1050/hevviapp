{#
/**
 * GeoArea Selection Widget Template
 *
 * Шаблон для рендеринга поля выбора гео-зон с интерактивной картой.
 * Используется в Sonata Admin для полей типа GeoAreaSelectionType.
 */
#}

{% block geo_area_selection_widget %}
    {# Устанавливаем значения по умолчанию если не переданы #}
    {% set enable_map = enable_map|default(true) %}
    {% set show_country_filter = show_country_filter|default(true) %}

    {# DEBUG: Проверка условий #}
    {# enable_map = {{ enable_map }}, show_country_filter = {{ show_country_filter }} #}
    {# map_config.default_latitude = {{ map_config.default_latitude }} #}

    {% if enable_map and show_country_filter %}
        <div class="geo-area-selection-wrapper"
             data-controller="geo-area-map"
             data-geo-area-map-api-countries-url-value="{{ path('api_geo_area_countries') }}"
             data-geo-area-map-api-cities-url-value="{{ path('api_geo_area_cities') }}"
             data-geo-area-map-api-geometry-url-value="{{ path('api_geo_area_geometry', {'id': '__ID__'}) }}"
             data-geo-area-map-api-custom-areas-url-value="{{ path('api_geo_area_custom_areas') }}"
             data-geo-area-map-api-custom-area-create-url-value="{{ path('api_geo_area_custom_area_create') }}"
             data-geo-area-map-default-lat-value="{{ map_config.default_latitude }}"
             data-geo-area-map-default-lng-value="{{ map_config.default_longitude }}"
             data-geo-area-map-default-zoom-value="{{ map_config.default_zoom }}"
             data-geo-area-map-translation-no-country-value="{{ 'geo_area_selection.select.no_country'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-no-city-value="{{ 'geo_area_selection.select.no_city'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-loading-cities-value="{{ 'geo_area_selection.status.loading_cities'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-error-load-countries-value="{{ 'geo_area_selection.error.load_countries'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-error-load-cities-value="{{ 'geo_area_selection.error.load_cities'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-error-load-geometry-value="{{ 'geo_area_selection.error.load_geometry'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-error-area-already-added-value="{{ 'geo_area_selection.error.area_already_added'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-add-button-value="{{ 'geo_area_selection.button.add'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-remove-button-value="{{ 'geo_area_selection.button.remove'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-custom-area-loading-value="{{ 'custom_area.select.loading'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-custom-area-placeholder-value="{{ 'custom_area.select.placeholder'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-custom-area-created-value="{{ 'custom_area.message.created'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-custom-area-updated-value="{{ 'custom_area.message.updated'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-custom-area-save-error-value="{{ 'custom_area.message.save_error'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-custom-area-select-country-value="{{ 'custom_area.message.select_country_first'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-custom-area-modal-not-found-value="{{ 'custom_area.message.modal_not_found'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-custom-area-controller-not-found-value="{{ 'custom_area.message.controller_not_found'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-custom-area-edit-error-value="{{ 'custom_area.message.edit_load_error'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-custom-badge-value="{{ 'custom_area.badge.custom'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-edit-button-value="{{ 'custom_area.button.edit'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-create-custom-button-value="{{ 'geo_area_selection.button.create_custom_area'|trans({}, 'AppBundle') }}"
             data-geo-area-map-translation-no-selected-areas-value="{{ 'geo_area_selection.message.no_selected_areas'|trans({}, 'AppBundle') }}">

            <div class="row">
                {# Левая колонка: Фильтры и список #}
                <div class="col-md-4">
                    {# Селект страны - Select2 будет инициализирован автоматически Sonata Admin #}
                    <div class="form-group">
                        <label>{{ 'geo_area_selection.label.country'|trans({}, 'AppBundle') }}</label>
                        <select class="form-select"
                                data-geo-area-map-target="countrySelect"
                                data-placeholder="{{ 'geo_area_selection.select.no_country'|trans({}, 'AppBundle') }}">
                            <option
                                value="">{{ 'geo_area_selection.select.no_country'|trans({}, 'AppBundle') }}</option>
                        </select>
                        <small class="form-text text-muted">
                            <i class="fas fa-info-circle"></i>
                            {{ 'geo_area_selection.help.select_country_first'|trans({}, 'AppBundle') }}
                        </small>
                    </div>

                    {# Селект города с кнопкой добавления - Select2 будет инициализирован автоматически #}
                    <div class="form-group" data-geo-area-map-target="citySelectWrapper">
                        <label>{{ 'geo_area_selection.label.city'|trans({}, 'AppBundle') }}</label>
                        <div class="input-group">
                            <select class="form-select"
                                    data-geo-area-map-target="citySelect"
                                    data-placeholder="{{ 'geo_area_selection.select.no_city'|trans({}, 'AppBundle') }}"
                                    disabled>
                                <option
                                    value="">{{ 'geo_area_selection.select.no_city'|trans({}, 'AppBundle') }}</option>
                            </select>
                            <span class="input-group-btn">
                                <button type="button"
                                        class="btn btn-success"
                                        data-geo-area-map-target="addButton"
                                        data-action="geo-area-map#addGeoArea"
                                        disabled
                                        title="{{ 'geo_area_selection.button.add'|trans({}, 'AppBundle') }}">
                                <i class="fas fa-plus"></i>
                            </button>
                            </span>
                        </div>
                        <small class="form-text text-muted">
                            {{ 'geo_area_selection.help.select_city'|trans({}, 'AppBundle') }}
                        </small>
                    </div>

                    {# Селект кастомных зон с кнопкой добавления #}
                    <div class="form-group" data-geo-area-map-target="customAreaSelectWrapper">
                        <label>{{ 'geo_area_selection.label.custom_area'|trans({}, 'AppBundle') }}</label>
                        <div class="input-group">
                            <select class="form-select"
                                    data-geo-area-map-target="customAreaSelect"
                                    data-placeholder="{{ 'geo_area_selection.select.no_custom_area'|trans({}, 'AppBundle') }}"
                                    disabled>
                                <option value="">{{ 'geo_area_selection.select.no_custom_area'|trans({}, 'AppBundle') }}</option>
                            </select>
                            <span class="input-group-btn">
                                <button type="button"
                                        class="btn btn-success"
                                        data-geo-area-map-target="addCustomAreaButton"
                                        data-action="geo-area-map#addCustomArea"
                                        disabled
                                        title="{{ 'geo_area_selection.button.add'|trans({}, 'AppBundle') }}">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </span>
                        </div>
                        <small class="form-text text-muted">
                            {{ 'geo_area_selection.help.select_custom_area'|trans({}, 'AppBundle') }}
                        </small>
                    </div>

                    {# Кнопка создания новой кастомной зоны #}
                    <div class="form-group">
                        <button type="button"
                                class="btn btn-primary w-100"
                                data-geo-area-map-target="createCustomAreaButton"
                                data-action="geo-area-map#openCreateCustomAreaModal"
                                disabled
                                title="{{ 'geo_area_selection.button.create_custom_area'|trans({}, 'AppBundle') }}">
                            <i class="fas fa-plus-circle"></i>
                            {{ 'geo_area_selection.button.create_custom_area'|trans({}, 'AppBundle') }}
                        </button>
                    </div>

                    {# Список выбранных зон #}
                    <div class="form-group">
                        <label>{{ 'geo_area_selection.label.selected_areas'|trans({}, 'AppBundle') }}</label>
                        <div class="selected-areas-list p-2"
                             style="max-height: 300px; overflow-y: auto;"
                             data-geo-area-map-target="selectedList">
                            <div
                                class="text-muted small">{{ 'geo_area_selection.message.no_selected'|trans({}, 'AppBundle') }}</div>
                        </div>
                    </div>
                </div>

                {# Правая колонка: Карта #}
                <div class="col-md-8">
                    {# Панель управления гексагональной сеткой #}
                    <div class="form-group hexagon-controls mb-3 p-3 border rounded bg-light" style="padding: 15px;">
                        <div class="row align-items-center">
                            <div class="col-md-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="hexagonGridToggle"
                                           data-geo-area-map-target="hexagonToggle">
                                    <label class="form-check-label" for="hexagonGridToggle">
                                        <i class="fas fa-th"></i>
                                        {{ 'geo_area_selection.hexagon.toggle_grid'|trans({}, 'AppBundle') }}
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-8" data-geo-area-map-target="hexagonResolutionWrapper" style="display: none;">
                                <label class="form-label mb-1">
                                    {{ 'geo_area_selection.hexagon.resolution'|trans({}, 'AppBundle') }}:
                                    <strong data-geo-area-map-target="resolutionLabel">6</strong>
                                    <small class="text-muted" data-geo-area-map-target="resolutionInfo">(~36.13 км²)</small>
                                </label>
                                <input type="range"
                                       class="form-range"
                                       min="5"
                                       max="6"
                                       value="6"
                                       step="1"
                                       data-geo-area-map-target="hexagonResolution"
                                       data-action="geo-area-map#onHexagonResolutionChange">
                                <div class="d-flex justify-content-between">
                                    <small class="text-muted">5 (252 км²)</small>
                                    <small class="text-muted">6 (36 км²)</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="map-container border rounded"
                         data-geo-area-map-target="map"
                         style="height: 500px; width: 100%;"></div>
                    <div class="map-legend mt-2">
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i>
                            {{ 'geo_area_selection.help.map_info'|trans({}, 'AppBundle') }}
                        </small>
                    </div>
                </div>
            </div>

            {# Скрытое поле для хранения выбранных ID (стандартное Symfony поле) #}
            <div style="display: none;" data-geo-area-map-target="hiddenInput">
                {{ block('choice_widget') }}
            </div>

            {# Модальное окно для создания/редактирования кастомных зон #}
            {% include 'form/custom_area_modal.html.twig' %}
        </div>
    {% else %}
        {# Фолбек: обычный селект без карты #}
        {{ block('choice_widget') }}
    {% endif %}
{% endblock %}
