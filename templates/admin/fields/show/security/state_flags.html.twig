{% extends '@SonataAdmin/CRUD/base_show_field.html.twig' %}

{% block field %}
    {% set flags = object.readableStates %}
    {% set domain = field_description.options.catalogue ?? 'messages' %}

    {% if flags is empty %}
        <span class="badge bg-secondary">None</span>
    {% else %}
        {% for bit, label in flags %}
            {% set class = 'label-warning text-dark' %}
            {% if label == 'ENABLED' %}
                {% set class = 'label-success text-white' %}
            {% elseif label == 'DISABLED' %}
                {% set class = 'label-danger text-white' %}
            {% elseif label == 'DELETED' %}
                {% set class = 'label-dark text-white' %}
            {% endif %}
            <span class="badge {{ class }}">{{ label|trans({}, domain) }}</span>
        {% endfor %}
    {% endif %}
{% endblock %}
