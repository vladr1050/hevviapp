{% extends '@SonataAdmin/standard_layout.html.twig' %}

{% block title %}{{ 'ops_dashboard.title'|trans({}, 'AppBundle') }}{% endblock %}

{% block sonata_page_content %}
    <section class="content-header">
        <div class="row">
            <div class="col-md-5">
                <h1>
                    {{ 'ops_dashboard.title'|trans({}, 'AppBundle') }}
                    <small class="text-muted">
                        {% if isTest %}
                            {{ 'ops_dashboard.scope.test'|trans({}, 'AppBundle') }}
                        {% else %}
                            {{ 'ops_dashboard.scope.live'|trans({}, 'AppBundle') }}
                        {% endif %}
                    </small>
                </h1>
                <p class="text-muted">
                    {{ 'ops_dashboard.generated_at'|trans({
                        '%time%': data.generatedAt|date('Y-m-d H:i'),
                        '%tz%': data.timezone
                    }, 'AppBundle') }}
                    · {{ 'ops_dashboard.order_total'|trans({'%count%': data.orderTotal}, 'AppBundle') }}
                </p>
            </div>
            <div class="col-md-7">
                <form method="get" action="{{ path('admin_ops_dashboard') }}" class="form-inline" style="margin-top: 8px; text-align: right;">
                    <input type="hidden" name="isTest" value="{{ isTest ? 1 : 0 }}">
                    <div class="form-group" style="margin-right: 8px;">
                        <label for="ops-from" style="margin-right: 4px;">{{ 'ops_dashboard.filter.from'|trans({}, 'AppBundle') }}</label>
                        <input id="ops-from" type="date" name="from" value="{{ from }}" class="form-control input-sm">
                    </div>
                    <div class="form-group" style="margin-right: 8px;">
                        <label for="ops-to" style="margin-right: 4px;">{{ 'ops_dashboard.filter.to'|trans({}, 'AppBundle') }}</label>
                        <input id="ops-to" type="date" name="to" value="{{ to }}" class="form-control input-sm">
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary">{{ 'ops_dashboard.filter.apply'|trans({}, 'AppBundle') }}</button>
                </form>
                <div style="margin-top: 8px; text-align: right;">
                    <div class="btn-group" style="margin-right: 8px;">
                        {% for preset in presets %}
                            <a href="{{ path('admin_ops_dashboard', {isTest: preset.isTest, from: preset.from, to: preset.to}) }}"
                               class="btn btn-xs {{ from == preset.from and to == preset.to ? 'btn-info' : 'btn-default' }}">
                                {{ preset.label_key|trans({}, 'AppBundle') }}
                            </a>
                        {% endfor %}
                    </div>
                    <div class="btn-group">
                        <a href="{{ path('admin_ops_dashboard', filterQuery|merge({isTest: 0})) }}"
                           class="btn btn-sm {{ not isTest ? 'btn-primary' : 'btn-default' }}">
                            {{ 'ops_dashboard.filter.live'|trans({}, 'AppBundle') }}
                        </a>
                        <a href="{{ path('admin_ops_dashboard', filterQuery|merge({isTest: 1})) }}"
                           class="btn btn-sm {{ isTest ? 'btn-warning' : 'btn-default' }}">
                            {{ 'ops_dashboard.filter.test'|trans({}, 'AppBundle') }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="content">
        <p class="text-muted" style="margin-top: 0;">
            {{ 'ops_dashboard.period.label'|trans({'%from%': from, '%to%': to}, 'AppBundle') }}
        </p>

        {# Period activity KPIs #}
        <div class="row">
            <div class="col-md-3 col-sm-6">
                <div class="info-box">
                    <span class="info-box-icon bg-aqua"><i class="fas fa-plus"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">{{ 'ops_dashboard.kpi.period_new'|trans({}, 'AppBundle') }}</span>
                        <span class="info-box-number">{{ data.periodNewCount }}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="info-box">
                    <span class="info-box-icon bg-green"><i class="fas fa-credit-card"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">{{ 'ops_dashboard.kpi.period_paid'|trans({}, 'AppBundle') }}</span>
                        <span class="info-box-number">{{ data.periodPaidCount }}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="info-box">
                    <span class="info-box-icon bg-purple"><i class="fas fa-check"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">{{ 'ops_dashboard.kpi.period_delivered'|trans({}, 'AppBundle') }}</span>
                        <span class="info-box-number">{{ data.periodDeliveredCount }}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="info-box">
                    <span class="info-box-icon bg-red"><i class="fas fa-envelope"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">{{ 'ops_dashboard.kpi.period_email_fail'|trans({}, 'AppBundle') }}</span>
                        <span class="info-box-number">{{ data.periodFailedNotificationsCount }}</span>
                    </div>
                </div>
            </div>
        </div>

        {# Finance for period (invoices by issue date) #}
        <div class="row">
            <div class="col-md-12">
                <div class="box box-success">
                    <div class="box-header with-border">
                        <h3 class="box-title">{{ 'ops_dashboard.finance.title'|trans({}, 'AppBundle') }}</h3>
                        <span class="badge bg-green">{{ data.finance.invoiceCount }}</span>
                        <p class="text-muted" style="margin: 6px 0 0; font-weight: normal; font-size: 12px;">
                            {{ 'ops_dashboard.finance.hint'|trans({}, 'AppBundle') }}
                        </p>
                    </div>
                    <div class="box-body">
                        <div class="row">
                            <div class="col-md-3 col-sm-6">
                                <p class="text-muted" style="margin-bottom: 4px;">{{ 'ops_dashboard.finance.freight'|trans({}, 'AppBundle') }}</p>
                                <p class="lead" style="margin-top: 0;">
                                    <strong>{{ data.finance.freightNetCents|currency_convert(data.finance.currency) }}</strong>
                                </p>
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <p class="text-muted" style="margin-bottom: 4px;">{{ 'ops_dashboard.finance.commission'|trans({}, 'AppBundle') }}</p>
                                <p class="lead" style="margin-top: 0;">
                                    <strong>{{ data.finance.commissionNetCents|currency_convert(data.finance.currency) }}</strong>
                                </p>
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <p class="text-muted" style="margin-bottom: 4px;">{{ 'ops_dashboard.finance.vat'|trans({}, 'AppBundle') }}</p>
                                <p class="lead" style="margin-top: 0;">
                                    <strong>{{ data.finance.vatCents|currency_convert(data.finance.currency) }}</strong>
                                </p>
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <p class="text-muted" style="margin-bottom: 4px;">{{ 'ops_dashboard.finance.total'|trans({}, 'AppBundle') }}</p>
                                <p class="lead" style="margin-top: 0;">
                                    <strong>{{ data.finance.grossCents|currency_convert(data.finance.currency) }}</strong>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Stuck KPIs (current snapshot) #}
        <div class="row">
            <div class="col-md-3 col-sm-6">
                <div class="info-box bg-yellow">
                    <span class="info-box-icon"><i class="fas fa-pause"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">{{ 'ops_dashboard.kpi.stuck_paid'|trans({}, 'AppBundle') }}</span>
                        <span class="info-box-number">{{ data.stuckPaidCount }}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="info-box bg-orange">
                    <span class="info-box-icon"><i class="fas fa-clock"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">{{ 'ops_dashboard.kpi.stuck_offered'|trans({}, 'AppBundle') }}</span>
                        <span class="info-box-number">{{ data.stuckOfferedCount }}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="info-box bg-red">
                    <span class="info-box-icon"><i class="fas fa-exclamation-triangle"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">{{ 'ops_dashboard.kpi.sla_overdue'|trans({}, 'AppBundle') }}</span>
                        <span class="info-box-number">{{ data.slaOverdueCount }}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="info-box bg-maroon">
                    <span class="info-box-icon"><i class="fas fa-bell-slash"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">{{ 'ops_dashboard.kpi.failed_7d'|trans({}, 'AppBundle') }}</span>
                        <span class="info-box-number">{{ data.failedNotificationsCount }}</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            {# Status funnel #}
            <div class="col-md-4">
                <div class="box box-primary">
                    <div class="box-header with-border">
                        <h3 class="box-title">{{ 'ops_dashboard.funnel.title'|trans({}, 'AppBundle') }}</h3>
                    </div>
                    <div class="box-body table-responsive no-padding">
                        <table class="table table-hover">
                            <thead>
                            <tr>
                                <th>{{ 'ops_dashboard.col.status'|trans({}, 'AppBundle') }}</th>
                                <th class="text-right">{{ 'ops_dashboard.col.count'|trans({}, 'AppBundle') }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for name, code in statusOrder %}
                                {% set count = data.statusCounts[code]|default(0) %}
                                {% if count > 0 or name not in ['CANCELLED'] %}
                                    <tr>
                                        <td>
                                            <a href="{{ path('admin_app_order_list', {
                                                'filter': {
                                                    'status': {'value': code},
                                                    'isTest': {'value': isTestFilterValue}
                                                }
                                            }) }}">
                                                {{ name|trans({}, 'AppBundle') }}
                                            </a>
                                        </td>
                                        <td class="text-right"><strong>{{ count }}</strong></td>
                                    </tr>
                                {% endif %}
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            {# Stuck lists #}
            <div class="col-md-8">
                {% include 'admin/ops/_order_table.html.twig' with {
                    title: 'ops_dashboard.stuck_paid.title'|trans({}, 'AppBundle'),
                    hint: 'ops_dashboard.stuck_paid.hint'|trans({}, 'AppBundle'),
                    orders: data.stuckPaid,
                    total: data.stuckPaidCount,
                    box_class: 'box-warning'
                } %}

                {% include 'admin/ops/_order_table.html.twig' with {
                    title: 'ops_dashboard.sla_overdue.title'|trans({}, 'AppBundle'),
                    hint: 'ops_dashboard.sla_overdue.hint'|trans({}, 'AppBundle'),
                    orders: data.slaOverdue,
                    total: data.slaOverdueCount,
                    box_class: 'box-danger'
                } %}

                {% include 'admin/ops/_order_table.html.twig' with {
                    title: 'ops_dashboard.stuck_offered.title'|trans({}, 'AppBundle'),
                    hint: 'ops_dashboard.stuck_offered.hint'|trans({}, 'AppBundle'),
                    orders: data.stuckOffered,
                    total: data.stuckOfferedCount,
                    box_class: 'box-default'
                } %}
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                {% include 'admin/ops/_order_table.html.twig' with {
                    title: 'ops_dashboard.period_new.title'|trans({}, 'AppBundle'),
                    hint: null,
                    orders: data.periodNew,
                    total: data.periodNewCount,
                    box_class: 'box-info'
                } %}
            </div>
            <div class="col-md-6">
                {% include 'admin/ops/_order_table.html.twig' with {
                    title: 'ops_dashboard.period_paid.title'|trans({}, 'AppBundle'),
                    hint: null,
                    orders: data.periodPaid,
                    total: data.periodPaidCount,
                    box_class: 'box-success'
                } %}
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                {% include 'admin/ops/_order_table.html.twig' with {
                    title: 'ops_dashboard.period_delivered.title'|trans({}, 'AppBundle'),
                    hint: null,
                    orders: data.periodDelivered,
                    total: data.periodDeliveredCount,
                    box_class: 'box-primary'
                } %}
            </div>
            <div class="col-md-6">
                <div class="box box-danger">
                    <div class="box-header with-border">
                        <h3 class="box-title">{{ 'ops_dashboard.period_failed_emails.title'|trans({}, 'AppBundle') }}</h3>
                        <span class="badge bg-red">{{ data.periodFailedNotificationsCount }}</span>
                    </div>
                    <div class="box-body table-responsive no-padding">
                        {% if data.periodFailedNotifications is empty %}
                            <p class="text-muted" style="padding: 12px;">{{ 'ops_dashboard.empty'|trans({}, 'AppBundle') }}</p>
                        {% else %}
                            <table class="table table-hover">
                                <thead>
                                <tr>
                                    <th>{{ 'ops_dashboard.col.order'|trans({}, 'AppBundle') }}</th>
                                    <th>{{ 'ops_dashboard.col.recipient'|trans({}, 'AppBundle') }}</th>
                                    <th>{{ 'ops_dashboard.col.event'|trans({}, 'AppBundle') }}</th>
                                    <th>{{ 'ops_dashboard.col.when'|trans({}, 'AppBundle') }}</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for log in data.periodFailedNotifications %}
                                    {% set order = log.relatedOrder %}
                                    <tr>
                                        <td>
                                            {% if order %}
                                                <a href="{{ orderAdmin.generateObjectUrl('show', order) }}">
                                                    {{ order.reference }}
                                                </a>
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ notificationLogAdmin.generateObjectUrl('show', log) }}">
                                                {{ log.recipientEmail }}
                                            </a>
                                        </td>
                                        <td>{{ log.eventKey }}</td>
                                        <td>{{ log.createdAt ? log.createdAt|date('Y-m-d H:i') : '—' }}</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
