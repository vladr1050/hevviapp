{#
/**
 * Template for displaying pickup and dropout addresses in a single field
 * with map view buttons for each address
 *
 * Variables:
 * - object: The current entity object (Order)
 */
#}
{% extends '@SonataAdmin/CRUD/base_list_field.html.twig' %}

{% block field %}
    {% set pickup_id = 'address_pickup_' ~ random() %}
    {% set dropout_id = 'address_dropout_' ~ random() %}
    {% set map_config = map_config() %}
    {% set pickup_address = object.pickupAddress %}
    {% set dropout_address = object.dropoutAddress %}

    <div class="addresses-combined">
        {# Pickup Address #}
        <div
            class="address-row mb-2"
            data-controller="address-view"
            data-address-view-address-value="{{ pickup_address }}"
            data-address-view-nominatim-url-value="{{ map_config.nominatim_url }}"
            data-address-view-default-lat-value="{{ map_config.default_lat }}"
            data-address-view-default-lng-value="{{ map_config.default_lng }}"
            data-address-view-default-zoom-value="{{ map_config.default_zoom }}"
            data-address-view-user-agent-value="{{ map_config.user_agent }}"
            data-address-view-error-geocoding-value="{{ 'address_view.error.geocoding_failed'|trans({}, 'AppBundle') }}"
            data-address-view-loading-text-value="{{ 'address_view.status.loading'|trans({}, 'AppBundle') }}"
        >
            <div class="d-flex align-items-center">
                <div class="flex-grow-1">
                    <small class="text-muted d-block">{{ 'list.label_pickup_address'|trans({}, 'AppBundle') }}</small>
                    <span class="address-text">{{ pickup_address }}</span>
                </div>
                <button
                    type="button"
                    class="btn btn-sm btn-outline-primary ms-2"
                    data-action="click->address-view#openModal"
                    title="{{ 'address_view.button.view_on_map'|trans({}, 'AppBundle') }}"
                >
                    <i class="fas fa-map-marked-alt"></i>
                </button>
            </div>

            {# Modal для pickup адреса #}
            <div
                class="modal fade address-view-modal"
                id="{{ pickup_id }}_modal"
                data-address-view-target="modal"
                tabindex="-1"
                role="dialog"
                aria-labelledby="{{ pickup_id }}_modal_label"
                aria-hidden="true"
            >
                <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="{{ pickup_id }}_modal_label">
                                <i class="fas fa-arrow-up text-success me-2"></i>
                                {{ 'address_view.modal.title_pickup'|trans({}, 'AppBundle') }}
                            </h5>
                        </div>
                        <div class="modal-body">
                            {# Индикатор загрузки #}
                            <div
                                class="alert alert-info text-center"
                                data-address-view-target="loadingIndicator"
                                style="display: none;"
                            >
                                <i class="fas fa-spinner fa-spin me-2"></i>
                                {{ 'address_view.status.loading'|trans({}, 'AppBundle') }}
                            </div>

                            {# Сообщение об ошибке #}
                            <div
                                class="alert alert-danger"
                                data-address-view-target="errorMessage"
                                style="display: none;"
                            ></div>

                            {# Информация об адресе #}
                            <div class="alert alert-secondary mb-3">
                                <strong>{{ 'address_view.modal.current_address'|trans({}, 'AppBundle') }}:</strong><br>
                                {{ pickup_address }}
                            </div>

                            {# Контейнер для карты #}
                            <div
                                id="{{ pickup_id }}_map"
                                data-address-view-target="map"
                                class="address-view-map"
                                style="height: 400px; width: 100%;"
                            ></div>
                        </div>
                        <div class="modal-footer">
                            <button
                                type="button"
                                class="btn btn-secondary"
                                data-action="click->address-view#closeModal"
                            >
                                {{ 'address_view.modal.button_close'|trans({}, 'AppBundle') }}
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Dropout Address #}
        <div
            class="address-row"
            data-controller="address-view"
            data-address-view-address-value="{{ dropout_address }}"
            data-address-view-nominatim-url-value="{{ map_config.nominatim_url }}"
            data-address-view-default-lat-value="{{ map_config.default_lat }}"
            data-address-view-default-lng-value="{{ map_config.default_lng }}"
            data-address-view-default-zoom-value="{{ map_config.default_zoom }}"
            data-address-view-user-agent-value="{{ map_config.user_agent }}"
            data-address-view-error-geocoding-value="{{ 'address_view.error.geocoding_failed'|trans({}, 'AppBundle') }}"
            data-address-view-loading-text-value="{{ 'address_view.status.loading'|trans({}, 'AppBundle') }}"
        >
            <div class="d-flex align-items-center">
                <div class="flex-grow-1">
                    <small class="text-muted d-block">{{ 'list.label_dropout_address'|trans({}, 'AppBundle') }}</small>
                    <span class="address-text">{{ dropout_address }}</span>
                </div>
                <button
                    type="button"
                    class="btn btn-sm btn-outline-primary ms-2"
                    data-action="click->address-view#openModal"
                    title="{{ 'address_view.button.view_on_map'|trans({}, 'AppBundle') }}"
                >
                    <i class="fas fa-map-marked-alt"></i>
                </button>
            </div>

            {# Modal для dropout адреса #}
            <div
                class="modal fade address-view-modal"
                id="{{ dropout_id }}_modal"
                data-address-view-target="modal"
                tabindex="-1"
                role="dialog"
                aria-labelledby="{{ dropout_id }}_modal_label"
                aria-hidden="true"
            >
                <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="{{ dropout_id }}_modal_label">
                                <i class="fas fa-arrow-down text-danger me-2"></i>
                                {{ 'address_view.modal.title_dropout'|trans({}, 'AppBundle') }}
                            </h5>
                        </div>
                        <div class="modal-body">
                            {# Индикатор загрузки #}
                            <div
                                class="alert alert-info text-center"
                                data-address-view-target="loadingIndicator"
                                style="display: none;"
                            >
                                <i class="fas fa-spinner fa-spin me-2"></i>
                                {{ 'address_view.status.loading'|trans({}, 'AppBundle') }}
                            </div>

                            {# Сообщение об ошибке #}
                            <div
                                class="alert alert-danger"
                                data-address-view-target="errorMessage"
                                style="display: none;"
                            ></div>

                            {# Информация об адресе #}
                            <div class="alert alert-secondary mb-3">
                                <strong>{{ 'address_view.modal.current_address'|trans({}, 'AppBundle') }}:</strong><br>
                                {{ dropout_address }}
                            </div>

                            {# Контейнер для карты #}
                            <div
                                id="{{ dropout_id }}_map"
                                data-address-view-target="map"
                                class="address-view-map"
                                style="height: 400px; width: 100%;"
                            ></div>
                        </div>
                        <div class="modal-footer">
                            <button
                                type="button"
                                class="btn btn-secondary"
                                data-action="click->address-view#closeModal"
                            >
                                {{ 'address_view.modal.button_close'|trans({}, 'AppBundle') }}
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
