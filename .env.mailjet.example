# Mailjet Configuration
# Получите ключи на https://app.mailjet.com/account/apikeys

# Mailjet API ключ (публичный ключ)
MAILJET_API_KEY=your_mailjet_api_key_here

# Mailjet API секрет (секретный ключ)
MAILJET_API_SECRET=your_mailjet_api_secret_here

# Email отправителя
MAILJET_SENDER_EMAIL=noreply@yourdomain.com

# Имя отправителя
MAILJET_SENDER_NAME="Your Company Name"

# Включить/выключить отправку email (true/false)
# Используйте false для тестирования без реальной отправки
MAILJET_ENABLED=true
