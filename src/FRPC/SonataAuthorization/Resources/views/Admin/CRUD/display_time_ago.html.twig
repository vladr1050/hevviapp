{%- apply spaceless %}
    {%- if value is empty -%}
        &nbsp;
    {%- else -%}
        <strong>{{ value|time_ago(full) }}</strong>
        {% if show_datetime %}
            | {{ 'at'|trans({}, "SonataAuthorizationBundle") }}
            <time datetime="{{ value|date('c', 'UTC') }}" title="{{ value|date('c', 'UTC') }}">
                {{ value|date(format|default(null), timezone|default(null)) }}
            </time>
        {% endif %}
    {%- endif -%}
{% endapply -%}